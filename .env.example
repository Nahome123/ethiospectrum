NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional for the credential-free marketing build. Configure both values for local Supabase Auth work.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only. Never prefix this with NEXT_PUBLIC or import it into Client Components.
SUPABASE_SECRET_KEY=

# Server-only secret used only to invoke the protected document-processing route.
# Use a distinct high-entropy value; never reuse SUPABASE_SECRET_KEY.
DOCUMENT_PROCESSING_SECRET=

# Server-only OpenAI configuration for controlled document summaries.
# Never prefix these values with NEXT_PUBLIC or expose them to browser code.
OPENAI_API_KEY=
OPENAI_SUMMARY_MODEL=

# Distinct server-only secret for the protected document-summary worker route.
# Never reuse DOCUMENT_PROCESSING_SECRET or SUPABASE_SECRET_KEY.
DOCUMENT_SUMMARY_SECRET=

# Server-only OCR provider configuration. Configure all three values together;
# never prefix them with NEXT_PUBLIC or commit real credentials.
OCR_PROVIDER=
OCR_API_KEY=
OCR_MODEL=

# Distinct server-only secret for the protected document-OCR worker route.
# Never reuse DOCUMENT_PROCESSING_SECRET, DOCUMENT_SUMMARY_SECRET, or SUPABASE_SECRET_KEY.
DOCUMENT_OCR_SECRET=
